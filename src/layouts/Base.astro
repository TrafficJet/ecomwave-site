---
export interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  ogImage?: string;
  type?: string;
  noindex?: boolean;
  schema?: object | object[];
}

const {
  title,
  description = 'EcomWave — AI-powered SEO tools for Shopify stores. Generate optimized product descriptions, meta tags, and titles in seconds.',
  canonicalUrl,
  ogImage = 'https://ecomwave.app/og-image.png',
  type = 'website',
  noindex = false,
  schema,
} = Astro.props;

const canon = canonicalUrl || Astro.url.href;

const breadcrumbJson = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://ecomwave.app/' },
  ],
};

const schemas = schema
  ? (Array.isArray(schema) ? schema : [schema])
  : [];
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canon} />
  {noindex && <meta name="robots" content="noindex,nofollow" />}

  <!-- OG -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canon} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:type" content={type} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Preconnect -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Schemas -->
  {schemas.map(s => (
    <script type="application/ld+json" set:html={JSON.stringify(s)} />
  ))}
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJson)} />

  <!-- GA (deferred) -->
  <script>
    window.addEventListener('load', function() {
      var s = document.createElement('script');
      s.src = 'https://www.googletagmanager.com/gtag/js?id=G-6E4FX4XZX0';
      s.async = true;
      document.head.appendChild(s);
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-6E4FX4XZX0');
    });
  </script>
</head>
<body class="bg-white text-gray-900 font-sans">

  <!-- Header -->
  <header class="sticky top-0 z-50 bg-white border-b border-gray-100 shadow-sm">
    <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 font-bold text-lg text-brand-700">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect width="28" height="28" rx="6" fill="#16a34a"/>
          <path d="M7 14l4 4 10-10" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        EcomWave
      </a>
      <nav class="hidden md:flex items-center gap-6 text-sm text-gray-600">
        <a href="/shopify-product-description-generator/" class="hover:text-brand-700 transition-colors">Description Generator</a>
        <a href="/shopify-meta-tags-optimizer/" class="hover:text-brand-700 transition-colors">Meta Tags</a>
        <a href="/bulk-product-seo-shopify/" class="hover:text-brand-700 transition-colors">Bulk SEO</a>
        <a href="/blog/" class="hover:text-brand-700 transition-colors">Blog</a>
        <a href="#pricing" class="hover:text-brand-700 transition-colors">Pricing</a>
      </nav>
      <a href="#pricing" class="bg-brand-600 hover:bg-brand-700 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors">
        Start Free Trial
      </a>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer class="bg-gray-900 text-gray-400 mt-20">
    <div class="max-w-6xl mx-auto px-4 py-12 grid grid-cols-2 md:grid-cols-4 gap-8">
      <div class="col-span-2 md:col-span-1">
        <div class="flex items-center gap-2 font-bold text-white mb-3">
          <svg width="22" height="22" viewBox="0 0 28 28" fill="none"><rect width="28" height="28" rx="6" fill="#16a34a"/><path d="M7 14l4 4 10-10" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          EcomWave
        </div>
        <p class="text-sm">AI-powered SEO tools built for Shopify merchants.</p>
      </div>
      <div>
        <h4 class="text-white font-medium mb-3 text-sm">Tools</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/shopify-product-description-generator/" class="hover:text-white transition-colors">Description Generator</a></li>
          <li><a href="/shopify-meta-tags-optimizer/" class="hover:text-white transition-colors">Meta Tags Optimizer</a></li>
          <li><a href="/shopify-product-title-generator/" class="hover:text-white transition-colors">Title Generator</a></li>
          <li><a href="/bulk-product-seo-shopify/" class="hover:text-white transition-colors">Bulk SEO</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-white font-medium mb-3 text-sm">Resources</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/blog/" class="hover:text-white transition-colors">Blog</a></li>
          <li><a href="/shopify-seo-checklist/" class="hover:text-white transition-colors">SEO Checklist</a></li>
          <li><a href="/shopify-seo-guide/" class="hover:text-white transition-colors">SEO Guide</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-white font-medium mb-3 text-sm">Company</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="#pricing" class="hover:text-white transition-colors">Pricing</a></li>
          <li><a href="/privacy/" class="hover:text-white transition-colors">Privacy</a></li>
          <li><a href="/terms/" class="hover:text-white transition-colors">Terms</a></li>
        </ul>
      </div>
    </div>
    <div class="border-t border-gray-800 text-center py-4 text-xs text-gray-600">
      © {new Date().getFullYear()} EcomWave. All rights reserved.
    </div>
  </footer>

</body>
</html>
