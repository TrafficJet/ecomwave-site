---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);
---

<Base
  title="Shopify SEO Blog — Tips, Guides & App Reviews | EcomWave"
  description="Practical Shopify SEO guides, app reviews, and optimization tactics from the EcomWave team. Grow your organic traffic without paid ads."
>

  <section class="pt-14 pb-8 px-4 bg-gradient-to-br from-brand-50 to-white">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-3">Shopify SEO Blog</h1>
      <p class="text-lg text-gray-600">Practical guides to grow your Shopify store's organic traffic.</p>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 py-12">
    <div class="grid md:grid-cols-2 gap-6">
      {posts.map(post => {
        const slug = post.data.slug || post.slug;
        return (
          <a href={`/blog/${slug}/`} class="group bg-white border border-gray-200 rounded-2xl p-6 hover:border-brand-300 hover:shadow-md transition-all">
            <div class="flex flex-wrap gap-2 mb-3">
              {(post.data.tags || []).slice(0, 2).map(tag => (
                <span class="bg-brand-50 text-brand-700 text-xs font-medium px-2 py-0.5 rounded-full">{tag}</span>
              ))}
            </div>
            <h2 class="font-bold text-gray-900 mb-2 group-hover:text-brand-700 transition-colors line-clamp-2">
              {post.data.title}
            </h2>
            {post.data.description && (
              <p class="text-sm text-gray-500 line-clamp-2 mb-3">{post.data.description}</p>
            )}
            <p class="text-xs text-gray-400">
              {new Date(post.data.pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </p>
          </a>
        );
      })}
    </div>
  </section>

</Base>
