---
import Base from '../layouts/Base.astro';

const appSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'EcomWave',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Shopify',
  description: 'AI-powered SEO tools for Shopify stores — product descriptions, meta tags, bulk optimization.',
  url: 'https://ecomwave.app/',
  offers: [
    {
      '@type': 'Offer',
      name: 'Free',
      price: '0',
      priceCurrency: 'USD',
      description: '5 products per month',
    },
    {
      '@type': 'Offer',
      name: 'Pro',
      price: '29',
      priceCurrency: 'USD',
      description: 'Unlimited products + bulk optimization',
    },
  ],
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.8',
    reviewCount: '47',
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is EcomWave?',
      acceptedAnswer: { '@type': 'Answer', text: 'EcomWave is a Shopify app that uses AI to generate SEO-optimized product descriptions, meta titles, and meta descriptions at scale.' },
    },
    {
      '@type': 'Question',
      name: 'How does EcomWave improve Shopify SEO?',
      acceptedAnswer: { '@type': 'Answer', text: 'EcomWave analyzes your product data and generates unique, keyword-rich descriptions and meta tags that satisfy Google\'s content quality guidelines and improve organic rankings.' },
    },
    {
      '@type': 'Question',
      name: 'Is EcomWave free?',
      acceptedAnswer: { '@type': 'Answer', text: 'EcomWave has a free plan for up to 5 products per month. The Pro plan at $29/month covers unlimited products and bulk processing.' },
    },
    {
      '@type': 'Question',
      name: 'How long does it take to generate product descriptions?',
      acceptedAnswer: { '@type': 'Answer', text: 'Individual descriptions generate in 3–5 seconds. Bulk processing handles 50 products in under 2 minutes.' },
    },
    {
      '@type': 'Question',
      name: 'Does EcomWave work with all Shopify themes?',
      acceptedAnswer: { '@type': 'Answer', text: 'Yes. EcomWave works within the Shopify admin and updates product data directly — it is theme-independent.' },
    },
  ],
};
---

<Base
  title="EcomWave — AI Shopify SEO Optimizer | Product Descriptions & Meta Tags"
  description="Generate SEO-optimized Shopify product descriptions, meta titles, and meta descriptions in seconds. Built for Shopify merchants who want organic traffic without the manual work."
  schema={[appSchema, faqSchema]}
>

  <!-- Hero -->
  <section class="bg-gradient-to-br from-brand-50 to-white pt-16 pb-20 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 bg-brand-100 text-brand-700 text-sm font-medium px-3 py-1 rounded-full mb-6">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1l1.5 4.5H14l-3.7 2.7 1.4 4.3L8 10l-3.7 2.5 1.4-4.3L2 5.5h4.5z"/></svg>
        Shopify App Store ★ 4.8 — 47 reviews
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 leading-tight mb-5">
        AI-Powered Shopify SEO.<br class="hidden md:block" />
        <span class="text-brand-600">Rank Higher. Sell More.</span>
      </h1>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto mb-8">
        Generate SEO-optimized product descriptions, meta tags, and titles in seconds. Stop losing organic traffic to stores with better copy.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="#pricing" class="w-full sm:w-auto bg-brand-600 hover:bg-brand-700 text-white font-semibold px-8 py-3.5 rounded-xl text-lg transition-colors shadow-lg shadow-brand-200">
          Start Free Trial — 14 days
        </a>
        <a href="/shopify-product-description-generator/" class="w-full sm:w-auto border border-gray-300 text-gray-700 font-medium px-8 py-3.5 rounded-xl text-lg hover:border-gray-400 transition-colors">
          See it in action →
        </a>
      </div>
      <p class="text-sm text-gray-500 mt-4">No credit card required · Installs in 60 seconds · Works with all themes</p>
    </div>
  </section>

  <!-- Before / After -->
  <section class="max-w-5xl mx-auto px-4 py-16">
    <h2 class="text-2xl md:text-3xl font-bold text-center text-gray-900 mb-3">From generic to Google-ready</h2>
    <p class="text-center text-gray-500 mb-10">What EcomWave does to your product listings</p>
    <div class="grid md:grid-cols-2 gap-6">
      <div class="border border-red-200 rounded-2xl p-6 bg-red-50">
        <div class="flex items-center gap-2 mb-4">
          <span class="w-6 h-6 bg-red-100 rounded-full flex items-center justify-center text-red-600 font-bold text-xs">✕</span>
          <span class="font-semibold text-red-700">Before EcomWave</span>
        </div>
        <p class="text-sm font-mono bg-white rounded-lg p-4 text-gray-600 border border-red-100">
          <strong>Title:</strong> Black T-Shirt Men<br/><br/>
          <strong>Description:</strong> This is a black t-shirt for men. It is made of cotton. Available in sizes S, M, L, XL.<br/><br/>
          <strong>Meta title:</strong> Black T-Shirt Men – My Store<br/>
          <strong>Meta desc:</strong> (empty)
        </p>
        <p class="text-xs text-red-600 mt-3">❌ No keywords · Duplicate content · Missing meta · Google ignores it</p>
      </div>
      <div class="border border-brand-200 rounded-2xl p-6 bg-brand-50">
        <div class="flex items-center gap-2 mb-4">
          <span class="w-6 h-6 bg-brand-100 rounded-full flex items-center justify-center text-brand-600 font-bold text-xs">✓</span>
          <span class="font-semibold text-brand-700">After EcomWave</span>
        </div>
        <p class="text-sm font-mono bg-white rounded-lg p-4 text-gray-700 border border-brand-100">
          <strong>Title:</strong> Men's Premium Cotton T-Shirt — Everyday Fit, All-Day Comfort<br/><br/>
          <strong>Description:</strong> Made from 100% ring-spun cotton, this men's t-shirt is built for all-day wear. Pre-shrunk fabric keeps its shape wash after wash. Available in S–XL.<br/><br/>
          <strong>Meta title:</strong> Men's Black Cotton T-Shirt | Free Shipping on $50+<br/>
          <strong>Meta desc:</strong> Shop our best-selling men's black t-shirt. 100% cotton, pre-shrunk, sizes S–XL. Free shipping on orders over $50.
        </p>
        <p class="text-xs text-brand-700 mt-3">✓ Target keywords · Unique copy · Full meta · Ranks in Google</p>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="bg-gray-50 py-16 px-4">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold text-center text-gray-900 mb-3">Everything your Shopify store needs to rank</h2>
      <p class="text-center text-gray-500 mb-12">Four tools. One app. Higher organic traffic.</p>
      <div class="grid md:grid-cols-2 gap-6">
        <a href="/shopify-product-description-generator/" class="bg-white rounded-2xl p-6 border border-gray-200 hover:border-brand-300 hover:shadow-md transition-all group">
          <div class="w-10 h-10 bg-brand-100 rounded-xl flex items-center justify-center mb-4 group-hover:bg-brand-200 transition-colors">
            <svg class="w-5 h-5 text-brand-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-2">Product Description Generator</h3>
          <p class="text-sm text-gray-600">AI writes unique, SEO-optimized descriptions from your product title and attributes. Generates in 3–5 seconds.</p>
        </a>
        <a href="/shopify-meta-tags-optimizer/" class="bg-white rounded-2xl p-6 border border-gray-200 hover:border-brand-300 hover:shadow-md transition-all group">
          <div class="w-10 h-10 bg-brand-100 rounded-xl flex items-center justify-center mb-4 group-hover:bg-brand-200 transition-colors">
            <svg class="w-5 h-5 text-brand-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-2">Meta Tags Optimizer</h3>
          <p class="text-sm text-gray-600">Optimize title tags and meta descriptions for every product, collection, and page. Preview exactly how you'll appear in Google.</p>
        </a>
        <a href="/bulk-product-seo-shopify/" class="bg-white rounded-2xl p-6 border border-gray-200 hover:border-brand-300 hover:shadow-md transition-all group">
          <div class="w-10 h-10 bg-brand-100 rounded-xl flex items-center justify-center mb-4 group-hover:bg-brand-200 transition-colors">
            <svg class="w-5 h-5 text-brand-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-2">Bulk SEO Optimization</h3>
          <p class="text-sm text-gray-600">Process 50, 500, or 5,000 products at once. Apply SEO improvements across your entire catalog in minutes.</p>
        </a>
        <a href="/shopify-product-title-generator/" class="bg-white rounded-2xl p-6 border border-gray-200 hover:border-brand-300 hover:shadow-md transition-all group">
          <div class="w-10 h-10 bg-brand-100 rounded-xl flex items-center justify-center mb-4 group-hover:bg-brand-200 transition-colors">
            <svg class="w-5 h-5 text-brand-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7h18M3 12h18M3 17h12"/></svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-2">Product Title Generator</h3>
          <p class="text-sm text-gray-600">Generate click-worthy, keyword-rich product titles that rank in search and convert better in shopping feeds.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Social Proof / Stats -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div>
          <div class="text-3xl font-bold text-brand-600 mb-1">4.8★</div>
          <div class="text-sm text-gray-500">App Store rating</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-brand-600 mb-1">50+</div>
          <div class="text-sm text-gray-500">Active stores</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-brand-600 mb-1">3 sec</div>
          <div class="text-sm text-gray-500">Per description</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-brand-600 mb-1">$0</div>
          <div class="text-sm text-gray-500">To get started</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section id="pricing" class="bg-gray-50 py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold text-center text-gray-900 mb-3">Simple pricing</h2>
      <p class="text-center text-gray-500 mb-10">Start free. Upgrade when you need more.</p>
      <div class="grid md:grid-cols-2 gap-6 max-w-2xl mx-auto">

        <!-- Free -->
        <div class="bg-white rounded-2xl p-8 border border-gray-200">
          <h3 class="font-bold text-xl text-gray-900 mb-1">Free</h3>
          <div class="text-3xl font-bold text-gray-900 mb-1">$0</div>
          <p class="text-sm text-gray-500 mb-6">Forever free, no card needed</p>
          <ul class="space-y-3 text-sm text-gray-700 mb-8">
            <li class="flex items-center gap-2"><span class="text-brand-600">✓</span> 5 products per month</li>
            <li class="flex items-center gap-2"><span class="text-brand-600">✓</span> AI product descriptions</li>
            <li class="flex items-center gap-2"><span class="text-brand-600">✓</span> Meta title + description</li>
            <li class="flex items-center gap-2"><span class="text-gray-300">—</span> <span class="text-gray-400">Bulk processing</span></li>
            <li class="flex items-center gap-2"><span class="text-gray-300">—</span> <span class="text-gray-400">Unlimited products</span></li>
          </ul>
          <a href="https://apps.shopify.com/ecomwave" class="block text-center border border-brand-600 text-brand-600 font-medium py-3 rounded-xl hover:bg-brand-50 transition-colors">
            Install Free
          </a>
        </div>

        <!-- Pro -->
        <div class="bg-brand-600 rounded-2xl p-8 border border-brand-700 relative overflow-hidden">
          <div class="absolute top-4 right-4 bg-white text-brand-700 text-xs font-bold px-2 py-1 rounded-full">MOST POPULAR</div>
          <h3 class="font-bold text-xl text-white mb-1">Pro</h3>
          <div class="text-3xl font-bold text-white mb-1">$29<span class="text-lg font-normal text-brand-200">/mo</span></div>
          <p class="text-sm text-brand-200 mb-6">14-day free trial, cancel anytime</p>
          <ul class="space-y-3 text-sm text-white mb-8">
            <li class="flex items-center gap-2"><span class="text-brand-200">✓</span> <strong>Unlimited</strong> products</li>
            <li class="flex items-center gap-2"><span class="text-brand-200">✓</span> AI product descriptions</li>
            <li class="flex items-center gap-2"><span class="text-brand-200">✓</span> Meta title + description</li>
            <li class="flex items-center gap-2"><span class="text-brand-200">✓</span> Bulk processing (50+ at once)</li>
            <li class="flex items-center gap-2"><span class="text-brand-200">✓</span> Priority support</li>
          </ul>
          <a href="https://apps.shopify.com/ecomwave" class="block text-center bg-white text-brand-700 font-semibold py-3 rounded-xl hover:bg-brand-50 transition-colors">
            Start 14-Day Free Trial
          </a>
        </div>
      </div>
      <p class="text-center text-sm text-gray-500 mt-6">Charged through Shopify. Cancel anytime from your app settings.</p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="max-w-3xl mx-auto px-4 py-16">
    <h2 class="text-2xl font-bold text-center text-gray-900 mb-10">Frequently asked questions</h2>
    <div class="space-y-4">
      {[
        ['What is EcomWave?', 'EcomWave is a Shopify app that uses AI to generate SEO-optimized product descriptions, meta titles, and meta descriptions at scale.'],
        ['How does EcomWave improve Shopify SEO?', "EcomWave analyzes your product data and generates unique, keyword-rich descriptions and meta tags that satisfy Google's content quality guidelines and improve organic rankings."],
        ['Is EcomWave free?', 'EcomWave has a free plan for up to 5 products per month. The Pro plan at $29/month covers unlimited products and bulk processing.'],
        ['How long does it take to generate product descriptions?', 'Individual descriptions generate in 3–5 seconds. Bulk processing handles 50 products in under 2 minutes.'],
        ['Does EcomWave work with all Shopify themes?', 'Yes. EcomWave works within the Shopify admin and updates product data directly — it is theme-independent.'],
      ].map(([q, a]) => (
        <details class="border border-gray-200 rounded-xl group">
          <summary class="flex items-center justify-between cursor-pointer px-6 py-4 font-medium text-gray-900 select-none">
            {q}
            <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="px-6 pb-4 text-gray-600 text-sm">{a}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="bg-brand-700 py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">Ready to rank your Shopify store?</h2>
      <p class="text-brand-200 mb-8">Join 50+ merchants using EcomWave to grow organic traffic without writing a single word manually.</p>
      <a href="https://apps.shopify.com/ecomwave" class="inline-block bg-white text-brand-700 font-bold px-10 py-4 rounded-xl text-lg hover:bg-brand-50 transition-colors shadow-lg">
        Install EcomWave — It's Free
      </a>
      <p class="text-brand-300 text-sm mt-4">No credit card · 60-second install · Works instantly</p>
    </div>
  </section>

</Base>
